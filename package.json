{
  "name": "sw-editor",
  "version": "0.0.0",
  "private": true,
  "description": "Serverless Workflow visual editor — monorepo root",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.30.3"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:examples": "playwright test --config example/playwright.config.ts",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@playwright/test": "1.58.2",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
